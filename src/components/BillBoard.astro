---
---
<div class="billboard my-9 table mx-auto text-center w-full lg:w-[970px] h-[250px]">
	<span class="text-xs text-zinc-500">PUBLICIDAD</span>
   <!--img src="https://beatdigital.com.mx/wp-content/uploads/2024/07/bilboard.jpg" alt="billboard" width="970" height="250"-->
   <div id="ad-slot3" class="hidden md:block" style="display:none;"></div>
   <div id="ad-slot31" class="md:hidden block" style="display:none;"></div>
   <div id="ad-slot3-adsense" style="display:none;">

	<ins class="adsbygoogle"
		style="display:block; height:250px; width:100%;"
		data-ad-client="ca-pub-7423640555477330"
		data-ad-slot="1885203366"
		data-ad-format="horizontal"
		data-full-width-responsive="true"></ins>

   </div>

	<script is:inline>
     let slot3Loaded = false;
     let slot31Loaded = false;
     let renderedCount = 0;

     googletag.cmd.push(function() {
       googletag.pubads().addEventListener('slotRenderEnded', function(event) {
         if (event.slot.getSlotElementId() === 'ad-slot3') {
           if (!event.isEmpty) slot3Loaded = true;
         }
         if (event.slot.getSlotElementId() === 'ad-slot31') {
           if (!event.isEmpty) slot31Loaded = true;
         }
         renderedCount++;
         if (renderedCount === 2) {
           if (slot3Loaded && slot31Loaded) {
             // Mostrar GPT slots
             document.getElementById('ad-slot3').style.display = '';
             document.getElementById('ad-slot31').style.display = '';
             document.querySelector('.ad-slot3-adsense').style.display = 'none';
           } else {
             // Mostrar AdSense
			 (adsbygoogle = window.adsbygoogle || []).push({});
             document.getElementById('ad-slot3').style.display = 'none';
             document.getElementById('ad-slot31').style.display = 'none';
             document.querySelector('.ad-slot3-adsense').style.display = 'block';
           }
         }
       });
     });
   </script>

</div>

