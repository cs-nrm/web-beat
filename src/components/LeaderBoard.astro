---

<div class="leader my-9 table mx-auto text-center w-[300px] md:w-[728px] h-[90px]">
	<span class="text-xs text-zinc-500">PUBLICIDAD</span>
	<!--img src="https://beatdigital.com.mx/wp-content/uploads/2024/07/leader.png" alt="leader" width="728" height="90"/-->
   <div id="ad-slot4" class="hidden md:block" style="display:none;"></div>
   <div id="ad-slot41" class="md:hidden block" style="display:none;"></div>

   <div class="ad-slot4-adsense" style="display:none;">
	<ins class="adsbygoogle"
		style="display:block; height:90px;"
		data-ad-client="ca-pub-7423640555477330"
		data-ad-slot="9572121691"
		data-ad-format="horizontal"
		data-full-width-responsive="true"></ins>
	<script is:inline>
		(adsbygoogle = window.adsbygoogle || []).push({});
	</script>
   </div>

	<script is:inline>
     let slot4Loaded = false;
     let slot41Loaded = false;
     let renderedCount = 0;

     googletag.cmd.push(function() {
       googletag.pubads().addEventListener('slotRenderEnded', function(event) {
         if (event.slot.getSlotElementId() === 'ad-slot4') {
           if (!event.isEmpty) slot4Loaded = true;
         }
         if (event.slot.getSlotElementId() === 'ad-slot41') {
           if (!event.isEmpty) slot41Loaded = true;
         }
         renderedCount++;
         if (renderedCount === 2) {
           if (slot4Loaded && slot41Loaded) {
             // Mostrar GPT slots
             document.getElementById('ad-slot4').style.display = '';
             document.getElementById('ad-slot41').style.display = '';
             document.querySelector('.ad-slot4-adsense').style.display = 'none';
           } else {
             // Mostrar AdSense
             document.getElementById('ad-slot4').style.display = 'none';
             document.getElementById('ad-slot41').style.display = 'none';
             document.querySelector('.ad-slot4-adsense').style.display = 'block';
           }
         }
       });
     });
   </script>
</div>